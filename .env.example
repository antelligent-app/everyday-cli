# EverydaySeries API Configuration
# Copy this file to .env and replace with your actual values

# Flow API Key (for EsClient - flow execution)
# Get your API key from: https://app.everydayseries.ai
EVERYDAY_API_KEY=es-your-api-key-here

# Database API Configuration (for EsDbClient - database operations)
# Get these from your Appwrite/EverydaySeries provider dashboard
EVERYDAY_PROJECT_ID=your-project-id-here
EVERYDAY_ENDPOINT=https://provider.everydayseries.ai/v1

# Optional: Default slug for flow execution
# EVERYDAY_SLUG=your-default-slug
