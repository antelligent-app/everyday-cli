{
  "$schema": "@antelligent-app/everyday-cli/schema",
  "version": "1.0.0",
  "database": {
    "id": "test_db",
    "name": "Test Database",
    "enabled": true
  },
  "collections": [
    {
      "id": "users",
      "name": "Users",
      "enabled": true,
      "documentSecurity": false,
      "permissions": [],
      "attributes": [
        {
          "key": "name",
          "type": "string",
          "required": true,
          "array": false,
          "size": 128,
          "default": null
        },
        {
          "key": "email",
          "type": "string",
          "required": true,
          "array": false,
          "size": 320,
          "default": null
        },
        {
          "key": "age",
          "type": "integer",
          "required": false,
          "array": false,
          "min": 0,
          "max": 150,
          "default": null
        },
        {
          "key": "bio",
          "type": "string",
          "required": false,
          "array": false,
          "size": 1000,
          "default": null
        },
        {
          "key": "isActive",
          "type": "boolean",
          "required": false,
          "array": false,
          "default": true
        }
      ],
      "indexes": [
        {
          "key": "email_index",
          "type": "unique",
          "attributes": [
            "email"
          ],
          "orders": [
            "ASC"
          ]
        },
        {
          "key": "name_index",
          "type": "key",
          "attributes": [
            "name"
          ],
          "orders": [
            "ASC"
          ]
        }
      ]
    },
    {
      "id": "posts",
      "name": "Blog Posts",
      "enabled": true,
      "documentSecurity": false,
      "permissions": [],
      "attributes": [
        {
          "key": "title",
          "type": "string",
          "required": true,
          "array": false,
          "size": 256,
          "default": null
        },
        {
          "key": "content",
          "type": "string",
          "required": true,
          "array": false,
          "size": 10000,
          "default": null
        },
        {
          "key": "authorId",
          "type": "string",
          "required": true,
          "array": false,
          "size": 128,
          "default": null
        },
        {
          "key": "publishDate",
          "type": "datetime",
          "required": false,
          "array": false,
          "default": null
        },
        {
          "key": "tags",
          "type": "string",
          "required": false,
          "array": true,
          "size": 50,
          "default": null
        },
        {
          "key": "published",
          "type": "boolean",
          "required": false,
          "array": false,
          "default": false
        },
        {
          "key": "views",
          "type": "integer",
          "required": false,
          "array": false,
          "min": 0,
          "max": 9223372036854776000,
          "default": 0
        },
        {
          "key": "status",
          "type": "string",
          "required": false,
          "array": false,
          "default": "draft",
          "elements": [
            "draft",
            "published",
            "archived"
          ]
        }
      ],
      "indexes": [
        {
          "key": "author_index",
          "type": "key",
          "attributes": [
            "authorId"
          ],
          "orders": [
            "ASC"
          ]
        },
        {
          "key": "published_date_index",
          "type": "key",
          "attributes": [
            "published",
            "publishDate"
          ],
          "orders": [
            "DESC",
            "DESC"
          ]
        }
      ]
    },
    {
      "id": "comments",
      "name": "Comments",
      "enabled": true,
      "documentSecurity": false,
      "permissions": [],
      "attributes": [
        {
          "key": "postId",
          "type": "string",
          "required": true,
          "array": false,
          "size": 128,
          "default": null
        },
        {
          "key": "userId",
          "type": "string",
          "required": true,
          "array": false,
          "size": 128,
          "default": null
        },
        {
          "key": "content",
          "type": "string",
          "required": true,
          "array": false,
          "size": 2000,
          "default": null
        },
        {
          "key": "likes",
          "type": "integer",
          "required": false,
          "array": false,
          "min": 0,
          "max": 9223372036854776000,
          "default": 0
        }
      ],
      "indexes": [
        {
          "key": "post_index",
          "type": "key",
          "attributes": [
            "postId"
          ],
          "orders": [
            "ASC"
          ]
        }
      ]
    }
  ],
  "buckets": [
    {
      "id": "avatars",
      "name": "User Avatars",
      "enabled": true,
      "maximumFileSize": 5242880,
      "allowedFileExtensions": [
        "jpg",
        "jpeg",
        "png",
        "gif",
        "webp"
      ],
      "compression": "gzip",
      "encryption": true,
      "antivirus": true,
      "permissions": []
    },
    {
      "id": "post_images",
      "name": "Post Images",
      "enabled": true,
      "maximumFileSize": 10485760,
      "allowedFileExtensions": [
        "jpg",
        "jpeg",
        "png",
        "gif",
        "webp"
      ],
      "compression": "gzip",
      "encryption": true,
      "antivirus": true,
      "permissions": []
    }
  ]
}