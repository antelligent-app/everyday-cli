{
  "name": "@antelligent-app/everyday-cli",
  "version": "2.0.6",
  "description": "TypeScript client and CLI for EverydaySeries API with server-side Account service, realtime subscriptions, preferences management, Magic URL auth, and dual environment support (Node.js & browser).",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "everyday-cli": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "node": {
        "import": "./dist/index.js",
        "require": "./dist/index.js"
      },
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "node": {
        "import": "./dist/server/index.js",
        "require": "./dist/server/index.js"
      },
      "default": "./dist/server/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "browser": "./dist/client/index.js",
      "import": "./dist/client/index.js",
      "require": "./dist/client/index.js",
      "default": "./dist/client/index.js"
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "CHANGELOG.md",
    "MIGRATION_V2.md",
    "V2.0.2_REAL_FIX.md",
    "NEXTJS_QUICK_START.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:clean && npm run build:server && npm run build:client",
    "build:clean": "rm -rf dist",
    "build:server": "tsc --project tsconfig.server.json",
    "build:client": "tsc --project tsconfig.client.json",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dev:cli": "ts-node src/cli.ts",
    "test": "jest",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "example": "ts-node examples/basic-usage.ts"
  },
  "keywords": [
    "everydayseries",
    "cli",
    "api-client",
    "typescript",
    "database",
    "appwrite",
    "realtime",
    "websocket",
    "subscriptions",
    "preferences",
    "magic-url",
    "passwordless",
    "authentication",
    "schema-management",
    "flow-execution",
    "automation",
    "workflow"
  ],
  "author": "Antelligent",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antelligent-app/everyday-cli.git"
  },
  "bugs": {
    "url": "https://github.com/antelligent-app/everyday-cli/issues"
  },
  "homepage": "https://github.com/antelligent-app/everyday-cli#readme",
  "devDependencies": {
    "@types/inquirer": "^8.2.10",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^9.39.4",
    "jest": "^30.4.2",
    "prettier": "^3.8.4",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "appwrite": "^26.0.0",
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "inquirer": "^8.2.6",
    "node-appwrite": "^26.2.0",
    "ora": "^5.4.1"
  }
}
