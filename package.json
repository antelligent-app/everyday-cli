{
  "name": "@koushikroy/everyday-cli",
  "version": "1.0.0",
  "description": "CLI and client library for EverydaySeries API - search and filter SAM.gov opportunities",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "everyday-cli": "dist/cli.js"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dev:cli": "ts-node src/cli.ts",
    "test": "jest",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "prepublishOnly": "npm run build",
    "example": "ts-node examples/basic-usage.ts"
  },
  "keywords": [
    "everydayseries",
    "sam.gov",
    "government",
    "contracts",
    "opportunities",
    "cli",
    "api-client"
  ],
  "author": "Antelligent",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antelligent-app/everyday-cli.git"
  },
  "bugs": {
    "url": "https://github.com/antelligent-app/everyday-cli/issues"
  },
  "homepage": "https://github.com/antelligent-app/everyday-cli#readme",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^9.39.4",
    "jest": "^30.4.2",
    "prettier": "^3.8.4",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
