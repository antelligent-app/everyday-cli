{
  "name": "@antelligent-app/everyday-cli",
  "version": "1.1.0",
  "description": "TypeScript client and CLI for EverydaySeries API - Execute flows, manage databases, and work with schemas",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "everyday-cli": "dist/cli.js"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dev:cli": "ts-node src/cli.ts",
    "test": "jest",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "example": "ts-node examples/basic-usage.ts"
  },
  "keywords": [
    "everydayseries",
    "cli",
    "api-client",
    "typescript",
    "database",
    "appwrite",
    "schema-management",
    "flow-execution",
    "automation",
    "workflow"
  ],
  "author": "Antelligent",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antelligent-app/everyday-cli.git"
  },
  "bugs": {
    "url": "https://github.com/antelligent-app/everyday-cli/issues"
  },
  "homepage": "https://github.com/antelligent-app/everyday-cli#readme",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.3",
    "@types/inquirer": "^8.2.10",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^9.39.4",
    "jest": "^30.4.2",
    "prettier": "^3.8.4",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "node-appwrite": "^26.2.0",
    "commander": "^12.0.0",
    "inquirer": "^8.2.6",
    "chalk": "^4.1.2",
    "ora": "^5.4.1"
  }
}
